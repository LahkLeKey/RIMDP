{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "rimdp: db init (first-run)",
      "type": "shell",
      "command": "node scripts/first-run-db-init.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "rimdp: docker compose up",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "rimdp: docker compose down",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "rimdp: dev all",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "rimdp: prepare stack",
      "dependsOrder": "sequence",
      "dependsOn": [
        "rimdp: docker compose up",
        "rimdp: db init (first-run)"
      ],
      "problemMatcher": []
    }
  ]
}